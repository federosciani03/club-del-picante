# ==========================================
# CLUB DEL PICANTE - Variables de entorno
# ==========================================
# Copiá este archivo como .env y completá los valores

# Servidor
PORT=3000
NODE_ENV=development

# MercadoPago - Conseguís estas claves en https://www.mercadopago.com.ar/developers
MP_ACCESS_TOKEN=TU_ACCESS_TOKEN_DE_MERCADOPAGO
MP_PUBLIC_KEY=TU_PUBLIC_KEY_DE_MERCADOPAGO

# JWT Secret - Cambiá esto por una cadena random larga y segura
JWT_SECRET=club_del_picante_secret_super_seguro_2024

# Admin credentials - Cambiá estos antes de producción
ADMIN_EMAIL=admin@clubdelpicante.com.ar
ADMIN_PASSWORD=ClubPicante2024!

# URL del sitio (para webhooks de MP)
SITE_URL=http://localhost:3000
